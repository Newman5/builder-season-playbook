{% extends "base.njk" %}

{% block title %}Data{% endblock %}

{% block content %}
<section class="hero">
  <p class="eyebrow">Raw Data</p>
  <h2 style="margin-top: 0;">Published JSON used by the site</h2>
  <p>This page links to the normalized builder registry, the generated GitHub activity snapshot, and the X weekly update archive and verifier outputs.</p>
</section>

<section class="card-grid">
  <article class="card">
    <h2>Builder Registry</h2>
    <p>Normalized JSON generated from <code>config/repos.yml</code>.</p>
    <a class="button secondary" href="{{ '/data/builders.json' | withBase }}">Open builders.json</a>
  </article>
  <article class="card">
    <h2>Activity Snapshot</h2>
    <p>Generated GitHub activity data for the current UTC week.</p>
    <a class="button secondary" href="{{ '/data/activity.json' | withBase }}">Open activity.json</a>
  </article>
  <article class="card">
    <h2>X Post Archive</h2>
    <p>Builder-submitted X posts normalized from YAML evidence files.</p>
    <a class="button secondary" href="{{ '/data/x-posts.json' | withBase }}">Open x-posts.json</a>
  </article>
  <article class="card">
    <h2>X Weekly Verifier</h2>
    <p>Per-builder weekly pass/fail results computed from submitted X evidence.</p>
    <a class="button secondary" href="{{ '/data/x-weeks.json' | withBase }}">Open x-weeks.json</a>
  </article>
</section>
{% endblock %}
